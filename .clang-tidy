Checks: >
  -*,
  clang-analyzer-*,
  bugprone-*,
  -bugprone-casting-through-void,
  -bugprone-multi-level-implicit-pointer-conversion,
  -bugprone-easily-swappable-parameters,
  cert-*,
  readability-*,
  performance-*,
  portability-*,
  -readability-magic-numbers,
HeaderFilterRegex: ".*/include/WasserXR/.*"
FormatStyle: file
